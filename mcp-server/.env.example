# Variables de entorno del MCP Server
# Copia este archivo como .env y completa los valores

# ── API meteorológica ──────────────────────────────────────────────────────────
# Clave de OpenWeatherMap (la misma que usa el workflow de n8n)
OPENWEATHER_API_KEY=tu_clave_aqui

# ── Servidor MCP ───────────────────────────────────────────────────────────────
# Puerto donde escucha el MCP Server (modo SSE)
MCP_PORT=3100
